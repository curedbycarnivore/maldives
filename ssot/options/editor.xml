<application>
  <component name="CodeInsightSettings">
    <option name="completionCaseSensitive" value="2" />
    <option name="AUTO_POPUP_JAVADOC_INFO" value="true" />
    <option name="JAVADOC_INFO_DELAY" value="1800" />
    <option name="COMPLETION_CASE_SENSITIVE" value="2" />
    <option name="INSERT_BRACE_ON_ENTER" value="false" />
    <option name="HIGHLIGHT_SCOPE" value="true" />
  </component>
  <component name="CodeVisionSettings">
    <option name="codeVisionGroupToPosition">
      <map>
        <entry key="inheritors" value="Right" />
        <entry key="references" value="Right" />
        <entry key="vcs.code.vision" value="Default" />
      </map>
    </option>
    <option name="defaultPosition" value="Right" />
    <option name="disabledCodeVisionProviderIds">
      <set>
        <option value="inheritors" />
        <option value="references" />
        <option value="vcs.code.vision" />
      </set>
    </option>
  </component>
  <component name="DaemonCodeAnalyzerSettings">
    <option name="AUTOREPARSE_DELAY" value="0" />
    <option name="SHOW_METHOD_SEPARATORS" value="true" />
  </component>
  <component name="DeclarativeInlayHintsSettings">
    <option name="enabledOptions">
      <map>
        <entry key="ts.type.hints#function.returns" value="false" />
      </map>
    </option>
  </component>
  <component name="EditorSettings">
    <option name="languageBreadcrumbsMap">
      <map>
        <entry key="CSS" value="true" />
        <entry key="HTML" value="true" />
        <entry key="JSON" value="true" />
        <entry key="JavaScript" value="true" />
        <entry key="SASS" value="true" />
        <entry key="SCSS" value="true" />
        <entry key="TypeScript" value="true" />
        <entry key="XHTML" value="true" />
        <entry key="XML" value="true" />
      </map>
    </option>
    <option name="USE_SOFT_WRAPS" value="CONSOLE:PREVIEW" />
    <option name="STRIP_TRAILING_SPACES" value="Whole" />
    <option name="IS_ENSURE_NEWLINE_AT_EOF" value="true" />
    <option name="REMOVE_TRAILING_BLANK_LINES" value="true" />
    <option name="SHOW_BREADCRUMBS_ABOVE" value="true" />
    <option name="ENABLE_RENDERED_DOC" value="true" />
  </component>
  <component name="InlayHintsSettings">
    <option name="lastViewedProviderKeyId" value="JavaScript.parameter.hints.old.js.only.show.names.for.tagged" />
    <settingsMapElement>
      <JavaScript.js.type.hints>
        <Settings>
          <option name="showForFunctions" value="true" />
          <option name="showForShorthandFunctions" value="true" />
          <option name="showForVariablesAndFields" value="true" />
        </Settings>
      </JavaScript.js.type.hints>
      <TypeScript.ts.type.hints>
        <Settings>
          <option name="showForFunctions" value="true" />
          <option name="showForShorthandFunctions" value="true" />
          <option name="showForVariablesAndFields" value="true" />
        </Settings>
      </TypeScript.ts.type.hints>
    </settingsMapElement>
  </component>
  <component name="InlineCompletionOnboarding">
    <option name="onboardingFinished" value="true" />
  </component>
  <component name="JSCodeFoldingSettings">
    <option name="collapseOneLineFunctions" value="true" />
  </component>
  <component name="JSEditorOptions">
    <option name="START_STRING_INTERPOLATION_ON_TYPING" value="true" />
  </component>
  <component name="LiveEditOptions" chromeUpdateJSOnChanges="true" restartIfHotSwapFailed="true" updateFilesToCompile="true" />
  <component name="TodoConfiguration">
    <pattern pattern="\bNotImplementedException\b" />
    <pattern pattern="(?&lt;=\W|^)(?&lt;TAG&gt;BUG)(\W|$)(.*)" />
    <pattern pattern="(?&lt;=\W|^)(?&lt;TAG&gt;TODO)(\W|$)(.*)" />
  </component>
</application>